generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  password_hash String
  name          String
  created_at    DateTime         @default(now())

  enrollments   enrollments[]
  video_progress video_progress[]
  refresh_tokens refresh_tokens[]
}

model subjects {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  is_published Boolean  @default(false)
  is_free      Boolean  @default(true)

  sections     sections[]
  enrollments  enrollments[]
}

model sections {
  id          Int      @id @default(autoincrement())
  subject_id  Int
  title       String
  order_index Int

  subject     subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  videos      videos[]

  @@index([subject_id])
}

model videos {
  id               Int      @id @default(autoincrement())
  section_id       Int
  title            String
  description     String?
  youtube_url     String
  order_index     Int
  duration_seconds Int

  section         sections @relation(fields: [section_id], references: [id], onDelete: Cascade)
  video_progress  video_progress[]

  @@unique([section_id, order_index])
  @@index([section_id])
}

model enrollments {
  user_id    Int
  subject_id Int

  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subject    subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@id([user_id, subject_id])
}

model video_progress {
  user_id              Int
  video_id             Int
  last_position_seconds Int      @default(0)
  is_completed         Boolean  @default(false)
  completed_at         DateTime?

  user                  users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video                 videos   @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@id([user_id, video_id])
  @@index([video_id])
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime @default(now())

  user       users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

